# Supabase (banco de dados, auth e storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API — OCR de notas e sugestões de investimento)
ANTHROPIC_API_KEY=

# Autenticação (login simples na tela de acesso)
# AUTH_SECRET: string aleatória longa (mínimo 32 caracteres). Use:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SECRET=

# Configurações da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000
FECHAMENTO_HORARIO=18:00
TIMEZONE=America/Sao_Paulo
